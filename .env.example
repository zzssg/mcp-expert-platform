# Template for the local .env (which is git-ignored). Copy to .env and fill in.
#   cp .env.example .env
# Loaded automatically at startup by DotEnvEnvironmentPostProcessor. Real OS env
# vars take precedence over values here.

# --- Gemini / Vertex REST proxy (the single model egress) --------------------
# The platform reaches Gemini only through this endpoint (Part 5.10 / 9 R1).
# Leave base-url EMPTY to boot without a model (catalog served; calls return ERROR).
VERTEX_BASE_URL=https://llm-proxy.example.internal
VERTEX_PROJECT=my-gcp-project
VERTEX_LOCATION=us-central1
VERTEX_TOKEN=replace-with-bearer-token
VERTEX_REQUEST_TIMEOUT=60s

# --- Model -------------------------------------------------------------------
# Swap to migrate Gemini 2.5 -> 3.x (config change only).
GEMINI_MODEL_ID=gemini-2.5-pro

# --- Token + latency budgets -------------------------------------------------
# max-input-tokens  -> prompt context reduction (diff kept, off-hunk context trimmed)
# max-output-tokens -> the model's output cap
# deadline          -> per-attempt model-call timeout
EXPERT_MAX_INPUT_TOKENS=60000
EXPERT_MAX_OUTPUT_TOKENS=8000
EXPERT_DEADLINE=30s
