{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "code_review_expert task",
  "type": "object",
  "additionalProperties": false,
  "required": ["diff"],
  "properties": {
    "diff": {
      "type": "string",
      "minLength": 1,
      "description": "Unified git diff under review (the primary evidence)."
    },
    "changedFiles": {
      "type": "array",
      "description": "Optional full after-image contents, to resolve citations beyond the diff hunks.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "afterContent": { "type": "string" }
        }
      }
    },
    "reviewProfile": {
      "type": "string",
      "enum": ["DEFAULT", "SECURITY", "CONCURRENCY", "PERFORMANCE"],
      "default": "DEFAULT",
      "description": "Raises/lowers defect-category emphasis."
    },
    "standards": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Bank coding-standard ids to enforce, e.g. no-field-injection."
    }
  }
}
